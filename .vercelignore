# Ignore VCS and config
.git/
.github/
.idea/
.vscode/

# Ignore mobile and desktop platforms (Vercel only builds Web)
android/
ios/
macos/
linux/
windows/

# Ignore build artifacts and local caches
.dart_tool/
build/
.vercel/
.home/
node_modules/

# Ignore python scripts and local utility scripts
*.exp
*.py
*.backup
setup.sh
setup2.sh
clean_check.sh
askpass.sh

# But do not ignore vercel-build.sh and vercel.json
!vercel-build.sh
!vercel.json
